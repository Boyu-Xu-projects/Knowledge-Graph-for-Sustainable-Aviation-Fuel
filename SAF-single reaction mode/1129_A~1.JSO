  "experiment_info": {
    "experiment_count": 1,
    "experiments": [
      {
        "experiment_id": 1,
        "reaction_type": "加氢处理",
        "reaction_type_english": "Hydroprocessing",
        "description": "在间歇式反应器中，使用一系列Cu/SiO₂-Al₂O₃和FeCu双金属催化剂（负载于SiO₂-Al₂O₃、ZSM-5和HZSM-5载体上），在300–340°C、2.07 MPa氢气压力下，对油酸进行催化加氢处理，以生产喷气燃料范围的烃类（C₈–C₁₆）。",
        "text_snippet": "The catalytic reactions were carried out in a Parr stirred batch reactor... Two g of each of the catalyst samples and 40 g of oleic acid were placed in the reactor and hydrogen gas was used to pressurize the reactor to 2.07 MPa... Cu/SiO₂-Al₂O₃ and FeCu/SiO₂-Al₂O₃ catalysts were evaluated at 340 °C. The temperatures of the reaction involving support optimization studies were set at 300, 320 and 340 °C.",
        "reaction_type_classify": "Hydrogenation reaction"
      }
    ]
  },
