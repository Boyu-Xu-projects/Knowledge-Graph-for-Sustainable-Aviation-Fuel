  "experiment_info": {
    "experiment_count": 3,
    "experiments": [
      {
        "experiment_id": 1,
        "reaction_type": "酮化反应与羟醛缩合反应",
        "reaction_type_english": "Ketonization and Aldol condensation reaction",
        "description": "在400°C、10 bar H₂条件下，使用2 wt% Cu/ZrO₂催化剂，通过重量时空速度(WHSV)为0.3 h⁻¹，将纯乙酸升级转化为芳香烃和环烯烃。反应涉及乙酸酮化为丙酮，随后进行羟醛缩合和环化反应。",
        "text_snippet": "We first carried out the upgrading of pure acetic acid as a model feed over 2 g of 2 wt% Cu/ZrO₂ at a weight hourly space velocity (WHSV) of 0.3 h⁻¹... The process resulted in a liquid product stream that spontaneously separated into an organic oil phase and an aqueous phase, in addition to a gas stream.",
        "reaction_type_classify": "Aldol condensation reaction"
      },
      {
        "experiment_id": 2,
        "reaction_type": "酮化反应与羟醛缩合反应",
        "reaction_type_english": "Ketonization and Aldol condensation reaction",
        "description": "在相同反应条件下，使用0.5 wt% Cu/ZrO₂催化剂升级50 wt%乙酸水溶液。降低铜负载量是为了减少丙酮加氢副反应，促进羟醛缩合。",
        "text_snippet": "Therefore, we used a catalyst for upgrading the dilute acetic acid feed that had a lower copper loading (0.5 wt%) compared to previous experiments (2 wt%)... At these reaction conditions, the conversion of acetone was reduced to 59.2%.",
        "reaction_type_classify": "Aldol condensation reaction"
      },
      {
        "experiment_id": 3,
        "reaction_type": "交叉酮化反应与羟醛缩合反应",
        "reaction_type_english": "Cross-Ketonization and Aldol condensation reaction",
        "description": "在400°C、10 bar H₂条件下，使用0.5 wt% Cu/ZrO₂催化剂，通过WHSV为0.2 h⁻¹，升级28/12 wt%乙酸/丁酸水溶液混合物。交叉酮化反应生成戊酮等中间体，进一步缩合形成更长碳链的产物。",
        "text_snippet": "We also performed cross-ketonization of acetic and butanoic acid to further increase the average carbon number of the organic oil... An initial model feed of 28/12 wt% aqueous acetic/butanoic acid feed was used... with a reduced WHSV of 0.2 h⁻¹, because longer chain ketones were slower to condense and required a longer residence time.",
        "reaction_type_classify": "Aldol condensation reaction"
      }
    ]
  },
