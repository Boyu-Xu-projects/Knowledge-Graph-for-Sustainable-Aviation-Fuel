  "experiment_info": {
    "experiment_count": 3,
    "experiments": [
      {
        "experiment_id": 1,
        "reaction_type": "转移加氢脱氧反应",
        "reaction_type_english": "Transfer hydrodeoxygenation reaction",
        "description": "使用RANEY® Ni催化剂，在463K下反应1小时，将纯PC颗粒在异丙醇中完全转化为C6-C15含氧化合物、芳烃和环烷烃的混合物",
        "text_snippet": "Over it, the pure PC pellet was completely converted to a mixture of C6–C15 oxygenates, aromatics and cycloalkanes after the reaction was carried out at 463 K for 1 h.",
        "reaction_type_classify": "Hydrogenation reaction"
      },
      {
        "experiment_id": 2,
        "reaction_type": "转移加氢脱氧反应",
        "reaction_type_english": "Transfer hydrodeoxygenation reaction",
        "description": "使用不同醇类（甲醇、乙醇、异丙醇、2-丁醇）作为氢供体，在463K下反应1小时，比较它们对PC降解的效果",
        "text_snippet": "Among the investigated alcohols, isopropanol exhibited the highest reactivity for the degradation of PC. The reactivities of different alcohols decreased in the order of isopropanol > 2-butanol > methanol > ethanol.",
        "reaction_type_classify": "Hydrogenation reaction"
      },
      {
        "experiment_id": 3,
        "reaction_type": "一锅法转移加氢脱氧反应",
        "reaction_type_english": "One-pot transfer hydrodeoxygenation reaction",
        "description": "使用RANEY® Ni和USY沸石作为共催化剂，在463K下分两步反应（第一步1小时，第二步1-5小时），将切碎的DVD光盘转化为C6-C15环烃，获得约75%的碳收率",
        "text_snippet": "Under the optimized conditions, an ∼75% carbon yield of C6–C15 cyclic hydrocarbons was achieved from the one-pot transfer hydrodeoxygenation of a chopped DVD disk under the co-catalysis of RANEY® Ni and USY.",
        "reaction_type_classify": "Hydrogenation reaction"
      }
    ]
  },
