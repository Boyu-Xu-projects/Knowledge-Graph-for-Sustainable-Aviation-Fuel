    "experiments": [
      {
        "experiment_id": 1,
        "reaction_type": "烷基化反应",
        "reaction_type_english": "Alkylation reaction",
        "description": "在间歇反应器中，使用HY、Hβ、WZr、S-ZrO2、γ-Al2O3和SiO2-Al2O3等固体酸催化剂，将第一步反应生成的环状醇与苯酚进行烷基化反应，生成二聚体化合物。",
        "text_snippet": "In the second step, cyclic alcohols were condensed with phenol. Solid catalysts, including HY, Hβ, WZr, S-ZrO2, γ-Al2O3, and SiO2–Al2O3 (0.1 g) were combined with the products from the first step and phenol (0.2 g) in the reactor. The reaction was performed at 160 ◦C and an H2 pressure of 4 MPa for 3 h.",
        "reaction_type_classify": "Alkylation reaction"
      },
      {
        "experiment_id": 2,
        "reaction_type": "烷基化反应",
        "reaction_type_english": "Alkylation reaction",
        "description": "在间歇反应器中，使用生物原油和添加的苯酚，通过HY、Hβ和WZr催化剂进行烷基化反应，生成二聚体化合物。",
        "text_snippet": "In the third step, the product obtained from the second step was alkylated with phenol. Three solid acid catalysts, namely HY, Hβ, and WZr [17], were used in the model compounds (0.3 g) and mixed with the product from the second step and phenol (0.2 g). The reaction was performed at 160 ◦C and an H2 pressure of 4 MPa for 3 h.",
        "reaction_type_classify": "Alkylation reaction"
      },
      {
        "experiment_id": 3,
        "reaction_type": "烷基化反应",
        "reaction_type_english": "Alkylation reaction",
        "description": "在连续流动固定床反应器中，使用Pd/C、NiFe/TiO2和HY催化剂进行一步法连续反应，通过烷基化生成C12或更高碳数的二聚环烷烃。",
        "text_snippet": "In the four-step one-pass continuous-flow fixed-bed reaction using bio-crude... The three-stage reaction was conducted for the third experiment, in which the Pd/C then NiFe/TiO2 then HY catalysts were used... Dimeric cycloalkanes (C12 or higher-carbon-number hydrocarbons) were distinctively formed by the alkylation between phenols and cyclic alcohols constituting fractions of 4.4–4.7 %",
        "reaction_type_classify": "Alkylation reaction"
      }
    ]
  },
