    "experiments": [
      {
        "experiment_id": 1,
        "reaction_type": "氢化反应",
        "reaction_type_english": "Hydrogenation reaction",
        "description": "使用Pd/C和HZSM-5双催化剂对2-苄基苯酚进行加氢，发生加氢脱氧和分子内环化竞争反应，生成二环己基甲烷和全氢芴。",
        "text_snippet": "The hydrogenation of 2-benzylphenol (i.e. 1) catalyzed by mixture of Pd/C and HZSM-5... about 29.1% dicyclohexylmethane (i.e. 6) and 68.9% perhydrofluorene (i.e. 9) are produced.",
        "reaction_type_classify": "Hydrogenation reaction"
      },
      {
        "experiment_id": 2,
        "reaction_type": "氢化反应",
        "reaction_type_english": "Hydrogenation reaction",
        "description": "仅使用Pd/C催化剂对2-苄基苯酚进行加氢，选择性发生分子内环化反应，高产率（96.7%）生成全氢芴。",
        "text_snippet": "when only Pd/C is used, 9 with yield of 96.7% is produced",
        "reaction_type_classify": "Hydrogenation reaction"
      },
      {
        "experiment_id": 3,
        "reaction_type": "氢化反应",
        "reaction_type_english": "Hydrogenation reaction",
        "description": "使用Pd/C和HY催化剂对2-苄基苯酚进行加氢，主要发生加氢脱氧反应，生成二环己基甲烷（产率97.1%）。",
        "text_snippet": "when HY with more and stronger acidity is used... 6 is produced with yield of 97.1%",
        "reaction_type_classify": "Hydrogenation reaction"
      },
      {
        "experiment_id": 4,
        "reaction_type": "氢化反应",
        "reaction_type_english": "Hydrogenation reaction",
        "description": "使用HZSM-5和Pd/C催化剂对2-苄基环己醇进行两步加氢脱氧反应，生成二环己基甲烷。",
        "text_snippet": "The time-dependent product distribution and proposed pathway are shown in Fig.4... 6 is the final product",
        "reaction_type_classify": "Hydrogenation reaction"
      },
      {
        "experiment_id": 5,
        "reaction_type": "氢化反应",
        "reaction_type_english": "Hydrogenation reaction",
        "description": "使用Pd/C催化剂对环己基(苯基)甲醇进行加氢，发生脱氢和加氢反应，生成(环己基甲基)苯和二环己基甲烷，未发生环化。",
        "text_snippet": "when only Pd/C is used as the catalyst, 6 is still the final product without any 9 formed. 7 is converted to 12 and 4 in parallel ways",
        "reaction_type_classify": "Hydrogenation reaction"
      }
    ]
  },
