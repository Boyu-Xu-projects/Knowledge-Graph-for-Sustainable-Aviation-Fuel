  "experiment_info": {
    "experiment_count": 2,
    "experiments": [
      {
        "experiment_id": 1,
        "reaction_type": "加氢脱氧反应",
        "reaction_type_english": "Hydrodeoxygenation reaction",
        "description": "在连续固定床反应器中，在钴改性ZSM-5催化剂上，于280-320°C、50 bar氢气压力下，将脂肪酸甲酯（FAMEs）转化为柴油和喷气燃料范围的烃类。",
        "text_snippet": "Catalytic hydrodeoxygenation of FAMEs was performed in a continuous fixed-bed reactor... The catalyst bed was cooled down to the desired reaction temperature (280−320 °C), and the H2 pressure was controlled as a fixed parameter at 50 bar in all test runs.",
        "reaction_type_classify": "Hydrogenation reaction"
      },
      {
        "experiment_id": 2,
        "reaction_type": "加氢异构化反应",
        "reaction_type_english": "Hydroisomerization reaction",
        "description": "在钴改性ZSM-5催化剂上，于加氢脱氧反应条件下，将直链烷烃异构化为支链烷烃，以改善燃料的冷流性能。",
        "text_snippet": "Its performance on FAMEs conversion was about 98%, providing mainly diesel products (n- and iso-C15−C18)... Furthermore, a sheet-like structure... giving a FAMEs conversion of 98% and more selective to jet-range fuel (n- and iso-C7−C14) of 33%.",
        "reaction_type_classify": "Hydrogenation reaction"
      }
    ]
  },
