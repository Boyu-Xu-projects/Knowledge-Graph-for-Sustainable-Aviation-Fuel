      {
        "experiment_id": 1,
        "reaction_type": "加氢脱氧反应",
        "reaction_type_english": "Hydrogenation reaction",
        "description": "使用Ru/Al₂O₃和H+-Y沸石催化剂在250°C、4 MPa H₂条件下对稀碱提取的玉米秸秆木质素进行水相加氢脱氧反应4小时",
        "text_snippet": "In a typical reaction, 100 mg lignin, 300 mg acid zeolite (H+-Y), 300 mg Ru/Al₂O₃, and 30 mL water were added into a 100 mL Parr reactor and reacted at 250°C under 4 MPa H₂ for 4 hours.",
        "reaction_type_classify": "Hydrogenation reaction"
      },
      {
        "experiment_id": 2,
        "reaction_type": "加氢脱氧反应",
        "reaction_type_english": "Hydrogenation reaction",
        "description": "单独使用Ru/Al₂O₃催化剂在相同条件下进行木质素加氢脱氧反应",
        "text_snippet": "Results showed that lignin conversion and the total product yield were relatively low (not exceeding 52% and 15%, respectively) when both catalysts were applied individually. The lignin conversion with H+-Y acidic zeolite was higher (52%) than that found with Ru/Al₂O₃ (31%)",
        "reaction_type_classify": "Hydrogenation reaction"
      },
      {
        "experiment_id": 3,
        "reaction_type": "加氢脱氧反应",
        "reaction_type_english": "Hydrogenation reaction",
        "description": "单独使用H+-Y酸性沸石催化剂在相同条件下进行木质素加氢脱氧反应",
        "text_snippet": "The main products resulting from catalysis with Ru/Al₂O₃ and acidic zeolite alone were found to be monocyclic alkyl cyclohexanes and phenols, respectively.",
        "reaction_type_classify": "Hydrogenation reaction"
      },
      {
        "experiment_id": 4,
        "reaction_type": "加氢脱氧反应",
        "reaction_type_english": "Hydrogenation reaction",
        "description": "使用1,2-二苯乙烷作为模型化合物在相同反应条件下进行加氢脱氧反应",
        "text_snippet": "Results showed high selectivity (95.5%) for aromatic ring hydrogenation of 1,2-diphenylethane to give the saturated product 1,2-dicyclohexylethane with no C–C bond cleavage",
        "reaction_type_classify": "Hydrogenation reaction"
      },
      {
        "experiment_id": 5,
        "reaction_type": "加氢脱氧反应",
        "reaction_type_english": "Hydrogenation reaction",
        "description": "使用2,2'-联苯酚作为模型化合物在相同反应条件下进行加氢脱氧反应",
